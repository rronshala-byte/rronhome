# ─────────────────────────────────────────────────────────────
# ImagoParturi — environment variables
#
# For the LOCAL DEMO you can leave everything blank.
# The site falls back to a local file store + console-logged
# emails so you can show the full flow with zero setup.
#
# Fill these in when you go LIVE (Vercel + Supabase + Resend).
# Copy this file to ".env.local" and fill in the values.
# ─────────────────────────────────────────────────────────────

# --- Supabase (database) ---------------------------------------
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (email) --------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=
# Sender address. For the demo you can use onboarding@resend.dev
# Later: bookings@imagoparturi.fi (after the domain is verified)
EMAIL_FROM=ImagoParturi <onboarding@resend.dev>
# Where the barber receives new-booking notifications
BARBER_EMAIL=

# --- Admin dashboard -------------------------------------------
# Password for /hallinta (the booking dashboard).
# Change this before sharing the live site.
ADMIN_PASSWORD=imago2026
